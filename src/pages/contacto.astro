---
import Layout from "@/layouts/Layout.astro";
import "@/styles/contacto.css";
---
<Layout title = "Contacto - Nido de Gracia 🙏" description="Ponte en contacto con nosotros para cualquier pregunta o solicitud de oración." url="https://nidodegracia.org/contacto">
    <section id="contacto" class="contacto">
      <section class="contacto__informacion">
        <h3>CONTACTANOS</h3>
        <p class="contacto__informacion__texto">
          Nos encantaría conocerte y ayudarte en tu caminar con Dios! Si tienes
          alguna pregunta, petición de oración o simplemente deseas hablar con
          alguien, no dudes en comunicarte con nosotros.
        </p>

      </section>
  
      <form class="formulario">
        <div class="formulario__grid">
            <label>
              <input
                name="nombre"
                type="text"
                class="formulario__nombre"
                placeholder="Nombre completo"

              />
              <p class="error" id="error-nombre"></p>
            </label>
            <label>
              <input
                name="email"
                type="email"
                class="formulario__correo"
                placeholder="Correo electronico"
              />
              <p class="error" id="error-email"></p>
            </label>
        </div>
        <label>
          <input name ="asunto" type="text" class="formulario__tema" placeholder="Asunto" />
          <p class="error" id="error-asunto"></p>
        </label>
        <label>
           <textarea
          class="formulario_mensaje"
          name="mensaje"
          placeholder="Mensaje"
        ></textarea>
        <p class="error" id="error-mensaje"></p>
        </label>
        <!-- <div  class="formulario__confirmacion">
          ✅ ¡Tu mensaje fue enviado con éxito! Te responderemos pronto.
        </div> -->
        <div class="formulario__consentimiento-wrapper">
          <label class="formulario__consentimiento">
            <input
              type="checkbox"
              id="consentimiento"
              name="consentimiento"
              class="formulario__checkbox"
            />
            <span class="formulario__checkbox-custom" aria-hidden="true"></span>
            <span class="formulario__consentimiento-texto">
              Acepto el tratamiento de mis datos personales (nombre completo y correo electrónico) con el único fin de recibir respuesta a mi consulta, conforme a nuestra <a href="/privacidad" target="_blank" class="formulario__consentimiento-link">política de privacidad</a>.
            </span>
          </label>
          <p class="error" id="error-consentimiento"></p>
        </div>
        <button type= "submit" class="formulario__btn">Enviar mensaje</button>
      </form>
    </section>
</Layout>

<script src="../utils/requestSendEmail.ts"></script>